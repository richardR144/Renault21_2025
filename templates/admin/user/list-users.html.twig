{% extends 'admin/base.html.twig' %}

{% block main %}
	<section id="admin-user-menu">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1>Gestion des utilisateurs</h1>
			<button type="button" onclick="window.location.href='{{ path('admin-create-user') }}'" class="btn btn-primary">
				<i class="fas fa-plus"></i>
				Créer un utilisateur
			</button>
		</div>

		{% for message in app.flashes('success') %}
			<div class="alert alert-success alert-dismissible fade show">
				{{ message }}
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		{% endfor %}
		{% for message in app.flashes('error') %}
			<div class="alert alert-danger alert-dismissible fade show">
				{{ message }}
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		{% endfor %}

		<div class="card" style="width: 95%; margin: 0 auto;">
			<div class="card-body p-2">
				<table class="table table-striped align-middle mb-0" style="width: 100%;">
					<thead class="table-dark">
						<tr>
							<th style="width: 8%;">ID</th>
							<th style="width: 25%;">Pseudo</th>
							<th style="width: 30%;">Email</th>
							<th style="width: 20%;">Rôles</th>
							<th style="width: 15%;">Membre depuis</th>
							<th style="width: 12%;">Statut</th>
							<th style="width: 17%;">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for user in users %}
							<tr>
								<td>{{ user.id }}</td>
								<td>
									<strong>{{ user.pseudo }}</strong>
                                    {% if user.online %}
                                        <span class="badge bg-success ms-1" title="{{ user.lastActivity }}">🟢</span>
                                    {% else %}
                                        <span class="badge bg-danger ms-1" title="{{ user.lastActivity }}">⚪</span>
                                    {% endif %}
								</td>
								<td>{{ user.email }}</td>
								<td>
									{% for role in user.roles %}
										<span class="badge bg-info">{{ role }}</span>
									{% endfor %}
								</td>
								<td>
									<small class="text-muted">{{ user.memberSince }}</small>
								</td>
								<td>
									{% if user.active %}
										<span class="badge bg-success">Actif</span>
									{% else %}
										<span class="badge bg-secondary">Inactif</span>
									{% endif %}
								</td>
								<td>
									<div class="btn-group btn-group-sm" role="group">
										<form method="post" action="{{ path('admin-edit-user', {'id': user.id}) }}" style="display:inline;" onsubmit="return confirm('Modifier l\'utilisateur {{ user.pseudo }} ?');">
											<input type="hidden" name="_token" value="{{ csrf_token('edit_user_' ~ user.id) }}">
											<button type="submit" class="btn btn-warning btn-sm" style="padding: 4px 8px; font-size: 0.8rem;">
												<i class="fas fa-edit"></i>Modifier</button>
										</form>
										<form method="post" action="{{ path('admin-delete-user', {'id': user.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer {{ user.pseudo }} ?');">
											<input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
											<button type="submit" class="btn btn-danger btn-sm" style="padding: 4px 8px; font-size: 0.8rem;">
												<i class="fas fa-trash"></i>
												Supprimer
											</button>
										</form>
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="5" class="text-center">Aucun utilisateur trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</section>
{% endblock %}
