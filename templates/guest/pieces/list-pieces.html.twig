{% extends ('guest/base.html.twig') %}

{% block metatitle %}Liste des Pièces | guest Renault 21 TD{% endblock metatitle %}




    {% block main %}
    
        <div class="list-pieces">
            <h1 class="text-center mb-4">Liste des pièces</h1>
            {% if pieces is empty %}
                <div class="empty-state text-center">
                    <h2>Aucune pièce trouvée</h2>
                    <p>Essayez une autre recherche ou créez une annonce.</p>
                    <a href="{{ path('create-piece') }}" class="btn btn-primary">Créer une annonce</a>
                </div>
            {% else %}

                <div class="pieces-grid">
                {% for piece in pieces %}
                <div class="piece">
                    <div class="piece-header d-flex justify-content-between align-items-center">
                        <h2 class="m-0">{{ piece.name }}</h2>
                        {% if piece.price %}
                            <span class="badge price-badge">{{ piece.price }} €</span>
                        {% elseif piece.isExchange %}
                            <span class="badge exchange-badge">Échange</span>
                        {% endif %}
                    </div>

                    {% if piece.image %}
                        <img src="{{ asset('Uploads/pieces/' ~ piece.image) }}" alt="Image de la pièce" class="piece-image" />
                    {% endif %}

                    <p class="piece-desc">{{ piece.description }}</p>

                    <div class="piece-meta">
                        <p>Categorie : {{ piece.name }}</p>
                        <p>Créé le : {{ piece.createdAt|date('Y-m-d') }}</p>
                        <p>Par {{ piece.user.pseudo }} — {{ piece.user.email }}</p>
                    </div>
                    <div class="piece-actions d-flex gap-2 mt-2">
                        <a href="{{ path('details-piece', {id: piece.id}) }}" class="btn btn-outline-primary btn-sm">Voir le détail</a>
                        {% if app.user and piece.user and app.user.id == piece.user.id %}
                            <a href="{{ path('update-piece', {id: piece.id}) }}" class="btn btn-outline-warning btn-sm">Modifier</a>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
                </div>
            {% endif %}

            <div class="pagination-controls d-flex justify-content-center align-items-center gap-3 mt-3">
                {% if totalPages is defined and currentPage is defined %}
                    {% if currentPage > 1 %}
                        <a class="btn btn-outline-primary" href="{{ path('list-pieces', { page: currentPage - 1 }) }}">Précédent</a>
                    {% endif %}
                    <span class="page-indicator">Page {{ currentPage }} / {{ totalPages }}</span>
                    {% if currentPage < totalPages %}
                        <a class="btn btn-outline-primary" href="{{ path('list-pieces', { page: currentPage + 1 }) }}">Suivant</a>
                    {% endif %}
                {% endif %}
            </div>

            {% for message in app.flashes('info') %}
                <div class="alert alert-info">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}
        </div>
{% endblock main %}



{% block javascripts %}
    <script src="{{ asset('js/guest/pieces/list-pieces.js') }}"></script>
{% endblock javascripts %}



