{% extends 'guest/base.html.twig' %}

{% block metatitle %}Profil utilisateur{% endblock %}

{% block main %}
<div class="container mt-4" style="max-width: 500px;">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0 text-center">Profil de {{ user.pseudo }}</h4>
        </div>
        <div class="card-body text-center">
            <p><strong>Email :</strong> {{ user.email }}</p>
            <p>
                Genre :
                {% if genre == 'female' %}
                    👧 Femme
                {% elseif genre == 'male' %}
                    👦 Homme
                {% else %}
                    Préfère ne pas dire
                {% endif %}
            </p>
        </div>
    </div>
</div>
{% endblock %}