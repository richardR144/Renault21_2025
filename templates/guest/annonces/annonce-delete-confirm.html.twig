{% extends 'guest/base.html.twig' %}

{% block metatitle %}Confirmer la suppression | Renault 21 TD{% endblock %}



{% block main %}
    <div class="container mt-4">
        <h1 class="mb-4 text-danger">Confirmer la suppression</h1>
        <div class="alert alert-warning">
            <p>Êtes-vous sûr de vouloir supprimer l'annonce <strong>{{ annonce.title }}</strong> ?</p>
        </div>
        <form action="{{ path('guest-annonce-delete', {id: annonce.id}) }}" method="post" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_annonce_' ~ annonce.id) }}">
            <button type="submit" class="btn btn-danger">Oui, supprimer</button>
            <a href="{{ path('guest-annonce-show', {id: annonce.id}) }}" class="btn btn-secondary ms-2">Annuler</a>
        </form>
        <p class="mt-3 text-muted">Cette action est irréversible.</p>
    </div>


            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}
        </div>
    </div>

{% endblock %}    

